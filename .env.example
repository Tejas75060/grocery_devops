# Copy to .env and adjust for your environment.
APP_NAME=Grocery Delivery Platform
ENVIRONMENT=dev

# Local dev default uses SQLite (no value needed). For Postgres:
# DATABASE_URL=postgresql://grocery:grocery@db:5432/grocery

# Optional HashiCorp Vault integration (Step 7). When set, DB creds are
# pulled from Vault and override DATABASE_URL above.
# VAULT_ADDR=http://vault:8200
# VAULT_TOKEN=root
# VAULT_SECRET_PATH=secret/data/grocery
